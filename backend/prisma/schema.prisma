generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ===================================================
// ENUMS
// ===================================================

enum Role {
  STUDENT
  ADMIN
}

enum TrustTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum LoanStatus {
  ACTIVE
  RETURNED
  OVERDUE
  LOST
}

enum ReservationStatus {
  PENDING      // waiting for book to become available
  NOTIFIED     // ✅ NEW — student notified, 48h window started
  FULFILLED    // student borrowed the book
  EXPIRED      // 48h window passed
  CANCELLED    // student cancelled
}

enum NotificationType {
  DUE_REMINDER
  OVERDUE_ALERT
  FINE_ALERT
  RESERVATION_AVAILABLE
  RESERVATION_EXPIRING
  TIER_CHANGE
  BOOK_REQUEST_UPDATE
  GENERAL
}

enum NotificationChannel {
  EMAIL
  IN_APP
  BOTH
}

enum PaymentMethod {
  ONLINE
  CASH
  LINK
}

enum PaymentStatus {
  CREATED
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum BookRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// ✅ NEW — Phase 6
enum LoanExtensionStatus {
  PENDING
  APPROVED
  REJECTED
}

// ===================================================
// MODELS
// ===================================================

model User {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  password  String
  role      Role      @default(STUDENT)
  isActive  Boolean   @default(true)
  trustTier TrustTier @default(BRONZE)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relations
  loans          Loan[]
  fines          Fine[]
  reservations   Reservation[]
  notifications  Notification[]
  payments       Payment[]
  bookRequests   BookRequest[]
  auditLogs      AuditLog[]
  loanExtensions LoanExtension[] // ✅ NEW — Phase 6
  readingGoal    ReadingGoal?    // ✅ NEW — Phase 6
  achievements   Achievement[]   // ✅ NEW — Phase 6

  @@index([role, isActive])
  @@map("users")
}

model Book {
  id              String   @id @default(uuid())
  title           String
  author          String
  isbn            String?  @unique
  genre           String
  totalCopies     Int      @default(1)
  availableCopies Int      @default(1)
  coverUrl        String?
  description     String?
  language        String   @default("English")
  publisher       String?
  year            Int?
  price           Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  loans        Loan[]
  reservations Reservation[]

  @@index([genre])
  @@map("books")
}

model Loan {
  id            String     @id @default(uuid())
  studentId     String
  bookId        String
  issuedAt      DateTime   @default(now())
  dueDate       DateTime
  returnedAt    DateTime?
  status        LoanStatus @default(ACTIVE)
  extendedCount Int        @default(0)

  // Relations
  student    User            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  book       Book            @relation(fields: [bookId], references: [id], onDelete: Cascade)
  fines      Fine[]
  extensions LoanExtension[] // ✅ NEW — Phase 6

  @@index([studentId, issuedAt])
  @@index([status, dueDate])
  @@index([bookId, status])
  @@map("loans")
}

model Fine {
  id            String         @id @default(uuid())
  loanId        String
  studentId     String
  amount        Float          @default(0)
  reason        String
  paidAt        DateTime?
  waivedBy      String?
  paymentId     String?
  paymentMethod PaymentMethod?
  createdAt     DateTime       @default(now())

  // Relations
  loan    Loan @relation(fields: [loanId], references: [id], onDelete: Cascade)
  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([loanId])
  @@index([studentId, paidAt, waivedBy])
  @@index([studentId, createdAt])
  @@index([createdAt])
  @@index([paidAt])
  @@map("fines")
}

model Reservation {
  id         String            @id @default(uuid())
  studentId  String
  bookId     String
  reservedAt DateTime          @default(now())
  expiresAt  DateTime
  notifiedAt DateTime?         // ✅ NEW — when student was notified
  status     ReservationStatus @default(PENDING)

  // Relations
  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)
  book    Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([bookId, status, reservedAt])
  @@index([studentId, bookId, status])
  @@index([studentId, reservedAt])
  @@index([status, expiresAt])
  @@map("reservations")
}

model Notification {
  id      String              @id @default(uuid())
  userId  String
  type    NotificationType
  message String
  channel NotificationChannel @default(BOTH)
  isRead  Boolean             @default(false)
  sentAt  DateTime            @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, sentAt])
  @@map("notifications")
}

model Payment {
  id            String        @id @default(uuid())
  receipt       String        @unique
  orderId       String?       @unique
  paymentId     String?
  linkId        String?
  studentId     String
  amount        Float
  method        PaymentMethod @default(ONLINE)
  status        PaymentStatus @default(CREATED)
  fineIds       Json
  failureReason String?
  createdBy     String?
  paidAt        DateTime?
  createdAt     DateTime      @default(now())

  // Relations
  student User @relation(fields: [studentId], references: [id])

  @@index([status])
  @@index([linkId])
  @@index([studentId, createdAt])
  @@index([createdAt])
  @@map("payments")
}

model BookRequest {
  id         String            @id @default(uuid())
  studentId  String
  title      String
  author     String
  genre      String?
  reason     String?
  status     BookRequestStatus @default(PENDING)
  adminNote  String?
  reviewedBy String?
  reviewedAt DateTime?
  createdAt  DateTime          @default(now())

  // Relations
  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, createdAt])
  @@index([status, createdAt])
  @@map("book_requests")
}

model AuditLog {
  id         String   @id @default(uuid())
  action     String
  actorId    String
  actorRole  String
  targetType String
  targetId   String
  details    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  // Relations
  actor User @relation(fields: [actorId], references: [id])

  @@index([actorId])
  @@index([action])
  @@index([createdAt])
  @@index([actorRole, createdAt])
  @@index([targetType, createdAt])
  @@map("audit_logs")
}

// ✅ NEW — Phase 6: Loan Extension System
model LoanExtension {
  id          String              @id @default(uuid())
  loanId      String
  studentId   String
  requestedAt DateTime            @default(now())
  newDueDate  DateTime
  status      LoanExtensionStatus @default(PENDING)
  adminNote   String?
  reviewedBy  String?
  reviewedAt  DateTime?

  // Relations
  loan    Loan @relation(fields: [loanId], references: [id], onDelete: Cascade)
  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([loanId])
  @@index([studentId, requestedAt])
  @@index([status, requestedAt])
  @@map("loan_extensions")
}

// ✅ NEW — Phase 6: Reading Goals
model ReadingGoal {
  id          String   @id @default(uuid())
  studentId   String   @unique
  monthlyGoal Int      @default(2)
  yearlyGoal  Int      @default(12)
  updatedAt   DateTime @updatedAt

  // Relations
  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("reading_goals")
}

// ✅ NEW — Phase 6: Achievements
model Achievement {
  id        String   @id @default(uuid())
  studentId String
  type      String
  earnedAt  DateTime @default(now())
  seen      Boolean  @default(false)

  // Relations
  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, type])
  @@index([studentId])
  @@map("achievements")
}