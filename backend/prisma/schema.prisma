generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ===================================================
// ENUMS
// ===================================================

enum Role {
  STUDENT
  ADMIN
}

enum TrustTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum LoanStatus {
  ACTIVE
  RETURNED
  OVERDUE
  LOST
}

enum ReservationStatus {
  PENDING
  FULFILLED
  EXPIRED
  CANCELLED
}

enum NotificationType {
  DUE_REMINDER
  OVERDUE_ALERT
  FINE_ALERT
  RESERVATION_AVAILABLE
  RESERVATION_EXPIRING
  TIER_CHANGE
  BOOK_REQUEST_UPDATE
  GENERAL
}

enum NotificationChannel {
  EMAIL
  IN_APP
  BOTH
}

// Phase 2.5 — Payment Gateway
enum PaymentMethod {
  ONLINE
  CASH
  LINK
}

enum PaymentStatus {
  CREATED
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

// ===================================================
// MODELS
// ===================================================

model User {
  id          String    @id @default(uuid())
  name        String
  email       String    @unique
  password    String
  role        Role      @default(STUDENT)
  isActive    Boolean   @default(true)
  trustTier   TrustTier @default(BRONZE)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  loans         Loan[]
  fines         Fine[]
  reservations  Reservation[]
  notifications Notification[]
  payments      Payment[]       // Phase 2.5

  @@map("users")
}

model Book {
  id              String   @id @default(uuid())
  title           String
  author          String
  isbn            String?  @unique
  genre           String
  totalCopies     Int      @default(1)
  availableCopies Int      @default(1)
  coverUrl        String?
  description     String?
  language        String   @default("English")
  publisher       String?
  year            Int?
  price           Float?   // Phase 2.5 — used for lost book replacement cost
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  loans        Loan[]
  reservations Reservation[]

  @@map("books")
}

model Loan {
  id            String     @id @default(uuid())
  studentId     String
  bookId        String
  issuedAt      DateTime   @default(now())
  dueDate       DateTime
  returnedAt    DateTime?
  status        LoanStatus @default(ACTIVE)
  extendedCount Int        @default(0)

  // Relations
  student User  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  book    Book  @relation(fields: [bookId], references: [id], onDelete: Cascade)
  fines   Fine[]

  @@index([studentId])
  @@index([bookId])
  @@index([status])
  @@map("loans")
}

model Fine {
  id            String    @id @default(uuid())
  loanId        String
  studentId     String
  amount        Float     @default(0)
  reason        String
  paidAt        DateTime?
  waivedBy      String?   // Admin user ID who waived it
  paymentId     String?   // Phase 2.5 — which Payment record cleared this fine
  paymentMethod String?   // Phase 2.5 — ONLINE | CASH | LINK | WAIVED
  createdAt     DateTime  @default(now())

  // Relations
  loan    Loan @relation(fields: [loanId], references: [id], onDelete: Cascade)
  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([loanId])
  @@map("fines")
}

model Reservation {
  id         String            @id @default(uuid())
  studentId  String
  bookId     String
  reservedAt DateTime          @default(now())
  expiresAt  DateTime
  status     ReservationStatus @default(PENDING)

  // Relations
  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)
  book    Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([bookId])
  @@index([status])
  @@map("reservations")
}

model Notification {
  id      String              @id @default(uuid())
  userId  String
  type    NotificationType
  message String
  channel NotificationChannel @default(BOTH)
  isRead  Boolean             @default(false)
  sentAt  DateTime            @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

// Phase 2.5 — Payment Gateway
model Payment {
  id            String        @id @default(uuid())
  receipt       String        @unique   // e.g. LIQ-17834621-4821
  orderId       String?       @unique   // Razorpay order ID (online payments)
  paymentId     String?                 // Razorpay payment ID (set after success)
  linkId        String?                 // Razorpay payment link ID (admin-generated)
  studentId     String
  amount        Float                   // Total ₹ being paid
  method        PaymentMethod @default(ONLINE)
  status        PaymentStatus @default(CREATED)
  fineIds       Json                    // String[] — array of fine IDs being paid
  failureReason String?                 // Set when status = FAILED
  createdBy     String?                 // Admin ID for CASH and LINK payments
  paidAt        DateTime?               // Set when status = SUCCESS
  createdAt     DateTime      @default(now())

  // Relations
  student User @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@index([status])
  @@index([orderId])
  @@map("payments")
}