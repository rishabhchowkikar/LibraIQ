generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ===================================================
// ENUMS
// ===================================================

enum Role {
  STUDENT
  ADMIN
}

enum TrustTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum LoanStatus {
  ACTIVE
  RETURNED
  OVERDUE
  LOST
}

enum ReservationStatus {
  PENDING
  FULFILLED
  EXPIRED
  CANCELLED
}

enum NotificationType {
  DUE_REMINDER
  OVERDUE_ALERT
  FINE_ALERT
  RESERVATION_AVAILABLE
  RESERVATION_EXPIRING
  TIER_CHANGE
  BOOK_REQUEST_UPDATE
  GENERAL
}

enum NotificationChannel {
  EMAIL
  IN_APP
  BOTH
}

enum PaymentMethod {
  ONLINE
  CASH
  LINK
}

enum PaymentStatus {
  CREATED
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

// ✅ NEW — Phase 5C
enum BookRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// ===================================================
// MODELS
// ===================================================

model User {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  password  String
  role      Role      @default(STUDENT)
  isActive  Boolean   @default(true)
  trustTier TrustTier @default(BRONZE)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relations
  loans         Loan[]
  fines         Fine[]
  reservations  Reservation[]
  notifications Notification[]
  payments      Payment[]
  bookRequests  BookRequest[]  // ✅ NEW — Phase 5C
  auditLogs     AuditLog[]    // ✅ NEW — Phase 5B

  @@map("users")
}

model Book {
  id              String   @id @default(uuid())
  title           String
  author          String
  isbn            String?  @unique
  genre           String
  totalCopies     Int      @default(1)
  availableCopies Int      @default(1)
  coverUrl        String?
  description     String?
  language        String   @default("English")
  publisher       String?
  year            Int?
  price           Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  loans        Loan[]
  reservations Reservation[]

  @@map("books")
}

model Loan {
  id            String     @id @default(uuid())
  studentId     String
  bookId        String
  issuedAt      DateTime   @default(now())
  dueDate       DateTime
  returnedAt    DateTime?
  status        LoanStatus @default(ACTIVE)
  extendedCount Int        @default(0)

  // Relations
  student User   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  book    Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  fines   Fine[]

  @@index([studentId])
  @@index([bookId])
  @@index([status])
  @@map("loans")
}

model Fine {
  id            String         @id @default(uuid())
  loanId        String
  studentId     String
  amount        Float          @default(0)
  reason        String
  paidAt        DateTime?
  waivedBy      String?
  paymentId     String?
  paymentMethod PaymentMethod? // ✅ FIXED — was String?, now uses enum
  createdAt     DateTime       @default(now())

  // Relations
  loan    Loan @relation(fields: [loanId], references: [id], onDelete: Cascade)
  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([loanId])
  @@map("fines")
}

model Reservation {
  id         String            @id @default(uuid())
  studentId  String
  bookId     String
  reservedAt DateTime          @default(now())
  expiresAt  DateTime
  status     ReservationStatus @default(PENDING)

  // Relations
  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)
  book    Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([bookId])
  @@index([status])
  @@map("reservations")
}

model Notification {
  id      String              @id @default(uuid())
  userId  String
  type    NotificationType
  message String
  channel NotificationChannel @default(BOTH)
  isRead  Boolean             @default(false)
  sentAt  DateTime            @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

model Payment {
  id            String        @id @default(uuid())
  receipt       String        @unique
  orderId       String?       @unique
  paymentId     String?
  linkId        String?
  studentId     String
  amount        Float
  method        PaymentMethod @default(ONLINE)
  status        PaymentStatus @default(CREATED)
  fineIds       Json
  failureReason String?
  createdBy     String?
  paidAt        DateTime?
  createdAt     DateTime      @default(now())

  // Relations
  student User @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@index([status])
  @@index([orderId])
  @@map("payments")
}

// ✅ NEW — Phase 5C: Book Request System
model BookRequest {
  id         String            @id @default(uuid())
  studentId  String
  title      String
  author     String
  genre      String?
  reason     String?
  status     BookRequestStatus @default(PENDING)
  adminNote  String?
  reviewedBy String?
  reviewedAt DateTime?
  createdAt  DateTime          @default(now())

  // Relations
  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([status])
  @@map("book_requests")
}

// ✅ NEW — Phase 5B: Audit Logs
model AuditLog {
  id         String   @id @default(uuid())
  action     String
  actorId    String
  actorRole  String
  targetType String
  targetId   String
  details    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  // Relations
  actor User @relation(fields: [actorId], references: [id])

  @@index([actorId])
  @@index([action])
  @@index([targetType])
  @@index([createdAt])
  @@map("audit_logs")
}